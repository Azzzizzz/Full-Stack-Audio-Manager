# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/meeami

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme-replace-with-long-random-string
JWT_TTL_MINUTES=60

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=

# Optional: override endpoint for local S3-compatible storage (e.g. MinIO)
# S3_ENDPOINT_URL=http://minio:9000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
