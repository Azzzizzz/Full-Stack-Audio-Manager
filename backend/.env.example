# MongoDB
MONGO_URI=mongodb://localhost:27017/meeami

# JWT — change this to a long random string in production
JWT_SECRET=changeme-use-a-long-random-string
JWT_TTL_MINUTES=60

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=
# Optional: override for local S3-compatible server (e.g. MinIO)
S3_ENDPOINT_URL=

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
